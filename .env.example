# Copy to .env and fill in. All values are optional; without a configured
# Foundry endpoint + key the backend returns a mock response for local dev.
FOUNDRY_RESPONSES_URL="https://<your-foundry-host>/responses"
FOUNDRY_API_KEY="your_foundry_api_key_here"
FOUNDRY_PROJECT="your_foundry_project_name_or_id"
FOUNDRY_MODEL="your_foundry_model_name_here"
DAG_WEB_SEARCH="true"
DAG_BACKEND_URL="http://localhost:8000"
DAG_DATA_DIR="data"

# RAG (Foundry IQ / Azure AI Search) — optional; enables "Goodies that worked for
# similar people" suggestions. Needs an Azure AI Search resource + an Azure OpenAI
# embeddings deployment. FOUNDRY_EMBEDDINGS_URL is derived from the responses URL
# (.../responses -> .../embeddings) unless set explicitly.
FOUNDRY_EMBEDDING_MODEL="text-embedding-3-large"
AZURE_SEARCH_ENDPOINT="https://<your-search>.search.windows.net"
AZURE_SEARCH_KEY="your_search_admin_key"
AZURE_SEARCH_INDEX="dag-goodies"
